@page
@model VideogameManager.Pages.Stats.IndexSModel
@{
    ViewData["Title"] = "Stats";
}

div class="container my-4">
<div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
    <h1 class="text-dark"><i class="bi bi-graph-up"></i> Quick Insights</h1>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0 text-center text-uppercase fw-bold">Top 5 Rated</h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var game in Model.TopFiveGames)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <div>
                                <span class="fw-bold text-dark">@game.Title</span>
                                <small class="text-muted d-block small">(@game.Developer?.Name)</small>
                            </div>
                            <span class="badge bg-primary rounded-pill fs-6">@game.Score</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0 text-center text-uppercase fw-bold">By Decade</h5>
            </div>
            <div class="card-body">
                @foreach (var item in Model.ByDecade)
                {
                    var percentage = Model.AllGames.Count > 0
                         ? (item.Count * 100.0 / Model.AllGames.Count).ToString("0", System.Globalization.CultureInfo.InvariantCulture)
                         : "0";
                        
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-bold text-secondary">@item.Decade's</span>
                            <span class="text-muted small">@item.Count (@percentage%)</span>
                        </div>
                        <div class="progress" style="height: 15px;">
                            <div class="progress-bar bg-success shadow-sm" role="progressbar"
                                 style="width: @(percentage)%;" aria-valuenow="@percentage"
                                 aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4 border-primary">
    <div class="card-header bg-dark text-white text-center fw-bold">
        DEVELOPER PERFORMANCE (AVG SCORE)
    </div>
    <div class="table-responsive">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Developer</th>
                    <th class="text-center">Games</th>
                    <th class="text-end pe-4">Average Score</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dev in Model.AvgPerDev)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@dev.Name</td>
                        <td class="text-center text-muted">@dev.GameCount</td>
                        <td class="text-end pe-4 text-primary fw-bold">@dev.AvgScore.ToString("F2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <span class="fw-bold text-uppercase small text-secondary">Productive Developers</span>
        <form method="get" class="d-flex align-items-center gap-2">
            <label class="small text-muted mb-0">Min. games:</label>
            <input type="number" asp-for="Threshold" class="form-control form-control-sm" style="width: 70px;" onchange="this.form.submit()" />
        </form>
    </div>
    <div class="card-body d-flex flex-wrap gap-2">
        @foreach (var dev in Model.producDevs)
        {
            <span class="badge rounded-pill border text-dark fw-normal p-2 px-3 bg-white shadow-sm border-primary">
                <i class="bi bi-person-badge me-1 text-primary"></i>
                <strong>@dev.Name</strong>
                <span class="ms-2 badge bg-secondary">@dev.Games.Count</span>
            </span>
        }
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary py-3">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label text-white small fw-bold">Title</label>
                <input type="text" asp-for="TitleFilter" placeholder="Search..." class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label text-white small fw-bold">Genre</label>
                <select asp-for="GenreSelected" asp-items="Model.Genres" class="form-select form-select-sm">
                    <option value="">All Genres</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label text-white small fw-bold">Since Year</label>
                <input type="number" asp-for="MinYear" placeholder="Year" class="form-control form-control-sm" />
            </div>
            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-dark btn-sm flex-grow-1 shadow-sm">
                    <i class="bi bi-funnel"></i> Filter
                </button>
                <a href="/Stats/IndexS" class="btn btn-light btn-sm shadow-sm border">Clear</a>
            </div>
        </form>
    </div>

    <div class="card-body bg-light">
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 g-3">
            @foreach (var game in Model.FilteredByNameGames)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm text-center p-3">
                        <div class="fw-bold text-truncate text-dark small" title="@game.Title">@game.Title</div>
                        <div class="text-muted" style="font-size: 0.75rem;">@game.Genre | @game.Year</div>
                        <div class="mt-2 fw-bold text-success">★ @game.Score</div>
                    </div>
                </div>
            }
        </div>
            
        @if (!Model.FilteredByNameGames.Any())
        {
            <div class="text-center py-4 text-muted">
                <i class="bi bi-search fs-2"></i>
                <p class="mt-2">No games match your search criteria.</p>
            </div>
        }
    </div>
</div>
</div>
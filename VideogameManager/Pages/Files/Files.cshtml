@page
@model VideogameManager.Pages.Files.FilesModel
@{
    ViewData["Title"] = "File Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-file-earmark-binary"></i> File Management</h1>
        <a asp-page="/Games/Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Games
        </a>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-code-slash"></i> JSON Persistence</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Full database backup. Use Import to overwrite the current list with the <code>games.json</code> file content.</p>
                    <form method="post">
                        <div class="d-grid gap-2">
                            <button type="submit" asp-page-handler="ExportJson" class="btn btn-sm btn-primary">
                                <i class="bi bi-download"></i> Export JSON
                            </button>
                            <button type="submit" asp-page-handler="ImportJson" class="btn btn-sm btn-outline-primary"
                                    onclick="return confirm('Are you sure? This will overwrite the current in-memory list.')">
                                <i class="bi bi-upload"></i> Import JSON
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-transparent border-0 text-center">
                    <small class="text-muted"><code>games.json</code></small>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-success">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-filetype-csv"></i> CSV Export</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Download the game list in a flat format compatible with Excel or Google Sheets.</p>
                    <form method="post">
                        <div class="d-grid gap-2">
                            <button type="submit" asp-page-handler="ExportCsv" class="btn btn-sm btn-success">
                                <i class="bi bi-file-earmark-arrow-down"></i> Download CSV
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-transparent border-0 text-center">
                    <small class="text-muted"><code>games.csv</code></small>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-info">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-filetype-xml"></i> XML Ranking</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Generates a ranking file ordered by <strong>Score</strong> (descending) using LINQ queries.</p>
                    <form method="post">
                        <div class="d-grid gap-2">
                            <button type="submit" asp-page-handler="ExportXml" class="btn btn-sm btn-info text-white">
                                <i class="bi bi-trophy"></i> Generate Ranking XML
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-transparent border-0 text-center">
                    <small class="text-muted"><code>games_ranking.xml</code></small>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-dark">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-journal-text"></i> Activity Log</h5>
                    <a asp-page="/Files" class="btn btn-sm btn-outline-light">
                        <i class="bi bi-arrow-clockwise"></i> Refresh Log
                    </a>
                </div>
                <div class="card-body bg-light">
                    @if (Model.LogEntries == null || Model.LogEntries.Length == 0)
                    {
                        <div class="text-center py-3">
                            <p class="text-muted mb-0">No activity recorded in <code>activity_log.txt</code>.</p>
                        </div>
                    }
                    else
                    {
                        <div class="bg-white border rounded p-3" style="max-height: 300px; overflow-y: auto;">
                            <pre class="mb-0" style="font-family: 'Courier New', Courier, monospace; font-size: 0.85rem;">@foreach (var line in Model.LogEntries){
                            @line
                            @Html.Raw("\n")
                            }
</pre>
                        </div>
                    }
                </div>
                <div class="card-footer text-muted small">
                    Changes are logged automatically on Create, Update, and Delete actions.
                </div>
            </div>
        </div>
    </div>
</div>
@page
@model VideogameManager.Pages.Files.FilesModel
@{
    ViewData["Title"] = "File Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-file-earmark-binary"></i> File Management</h1>
        <a asp-page="/Games/Index" class="btn btn-secondary">Back to Games</a>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-code-slash"></i> JSON Data Persistence</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Save the current list of games to <code>games.json</code> or load existing data from the file (this will overwrite the current list).</p>
                    
                    <form method="post">
                        <div class="d-grid gap-2">
                            <button type="submit" asp-page-handler="ExportJson" class="btn btn-primary">
                                <i class="bi bi-download"></i> Export to JSON
                            </button>
                            <button type="submit" asp-page-handler="ImportJson" class="btn btn-outline-primary"
                                    onclick="return confirm('Are you sure? This will overwrite the current in-memory list.')">
                                <i class="bi bi-upload"></i> Import from JSON
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center">
                    <small class="text-muted">File: <code>games.json</code></small>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-arrow-up"></i> Other Formats</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Additional export options (CSV and XML support coming soon):</p>
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-secondary" disabled>Export to CSV</button>
                        <button class="btn btn-outline-secondary" disabled>Export to XML</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-journal-text"></i> Activity Log</h5>
                    <a asp-page="/Files" class="btn btn-sm btn-outline-light">
                        <i class="bi bi-arrow-clockwise"></i> Refresh
                    </a>
                </div>
                <div class="card-body bg-light">
                    @if (Model.LogEntries == null || Model.LogEntries.Length == 0)
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-info-circle text-muted fs-2"></i>
                            <p class="text-muted mt-2">No activity recorded yet in <code>activity_log.txt</code>.</p>
                        </div>
                    }
                    else
                    {
                        <div class="bg-white border rounded p-3" style="max-height: 400px; overflow-y: auto;">
                            <pre class="mb-0" style="font-family: 'Courier New', Courier, monospace; font-size: 0.9rem;">
                                @foreach (var line in Model.LogEntries)
                                {
                                    @line
                                    @Html.Raw("\n")
                                }
                            </pre>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <small class="text-muted">Activity is logged automatically during Create, Update, and Delete operations.</small>
                </div>
            </div>
        </div>
    </div>
</div>

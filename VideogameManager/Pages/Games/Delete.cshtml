@page "{id:int}"
@model VideogameManager.Pages.Games.DeleteModel
@{
    ViewData["Title"] = "Delete Game";
}

<div class="container mt-4">
    <div class="alert alert-danger">
        <h3>Are you sure you want to delete this game?</h3>
        <p>This action cannot be undone.</p>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">@Model.Game.Title</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-2">Genre</dt>
                <dd class="col-sm-10">@Model.Game.Genre</dd>

                <dt class="col-sm-2">Year</dt>
                <dd class="col-sm-10">@Model.Game.Year</dd>

                <dt class="col-sm-2">Score</dt>
                <dd class="col-sm-10">@Model.Game.Score / 10</dd>

                <dt class="col-sm-2">Description</dt>
                <dd class="col-sm-10">@Model.Game.Description</dd>
            </dl>
        </div>
    </div>

    <form method="post">
        @* The ID is sent via the URL route "{id:int}", so a hidden input isn't strictly
           required, but we could use one if the route didn't include it. *@
        <button type="submit" class="btn btn-danger">Confirm Delete</button>
        <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>